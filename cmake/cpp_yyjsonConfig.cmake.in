@PACKAGE_INIT@

set(CPPYYJSON_VERSION @PROJECT_VERSION@)
set(CPPYYJSON_PFR_TARGET "@CPPYYJSON_PFR_TARGET@")

include(CMakeFindDependencyMacro)
find_dependency(yyjson CONFIG REQUIRED)
find_dependency(fmt 10.0.0 CONFIG REQUIRED)
find_dependency(nameof 0.10.0 CONFIG REQUIRED)

# Propagate boost::pfr dependency
if(NOT TARGET "@CPPYYJSON_PFR_TARGET@")
  find_dependency(boost_pfr CONFIG REQUIRED)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@Targets.cmake")
check_required_components("@PROJECT_NAME@")
